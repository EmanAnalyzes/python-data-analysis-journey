print("simle calculator")
 
a = float(input("enter a first number:"))
operators = input("choosse an operator(+,-,*,/)")
b = float(input("enter a  second number:"))
if operators == "+":
 print("result=", a + b)
elif operators == "-":
 print("result=",a - b )
elif operators == "*":
 print("result=", a * b )
elif operators == "/":
 print("result=", a/b )
else :
 print("Invalid operator")
